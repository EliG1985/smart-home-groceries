{
  "expo": {
    "name": "smarthome-groceries-mobile",
    "slug": "smarthome-groceries-mobile",
    "version": "0.1.0",
    "sdkVersion": "50.0.0",
    "scheme": "smarthomegroceries",
    "main": "index.js",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.smarthomegroceriesmobile",
      "associatedDomains": [
        "applinks:links.smarthomegroceries.app"
      ]
    },
    "android": {
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "links.smarthomegroceries.app",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "package": "com.anonymous.smarthomegroceriesmobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
