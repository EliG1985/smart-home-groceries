# Example environment variables for backend
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
PORT=4000

# Invite email sender label in subject/body (optional)
INVITE_EMAIL_APP_NAME=SmartHome Groceries

# Option A: Gmail quick test (requires 2FA + App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM=SmartHome Groceries <your.email@gmail.com>
# SMTP_REPLY_TO=your.email@gmail.com

# Option B: Single SMTP URL for other providers
# SendGrid example:
# SMTP_URL=smtps://apikey:SG_xxx@smtp.sendgrid.net:465
# SMTP_FROM=SmartHome Groceries <no-reply@yourdomain.com>
# SMTP_REPLY_TO=support@yourdomain.com
